# mio-memory 設定サンプル
# このファイルを .env にコピーして値を書き換えて使う
# cp .env_sample .env

# Bearer認証トークン兼OAuthログインパスワード（必須）
MIO_API_TOKEN=changeme

# サーバーの公開ベースURL（OAuth/share URLに使用）
# 本番環境: https://your-domain.com
# ローカル開発: http://localhost:5002（デフォルト）
MIO_BASE_URL=https://your-domain.com

# ログレベル: debug / info / off（デフォルト: info）
MIO_LOG_LEVEL=info

# 新規インストール時の CoreMem スケルトン言語: ja / en（デフォルト: ja）
# まっさらな環境の初回起動時だけ skeleton/coremem/<lang>/ を投入する。
# 既に CoreMem が入っている環境では無視される（既存データは保護）。
# 英語で始めたい場合のみ en に変更する。
# MIO_SEED_LANG=ja

# 許可するOriginヘッダー（カンマ区切り）
# 空のままにするとOrigin検証をスキップ（ローカル開発・curl向け）
# 本番環境では claude.ai を指定することを推奨
# MIO_ALLOWED_ORIGINS=https://claude.ai

# お友達システム（省略時はメール送信なしで動作）
# SENDGRID_API_KEY=SG.xxxxxxxxxxxx
# SENDGRID_FROM_EMAIL=mio@your-domain.com
# MIO_REGISTER_URL=https://your-domain.com  # 末尾スラッシュなし（/activate を自動付与）

# 要約バッチ（省略可）
# ZIP インポート後に要約バッチが自動起動する
# ANTHROPIC_API_KEY があれば anthropic、なければ LMStudio（ローカルLLM）を使う
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# LMStudio バックエンド設定（省略可）
# LM_STUDIO_HOST=192.168.10.32
# LM_STUDIO_PORT=1234

# 夜間自動バッチ（省略可）
# 毎日この時刻（JST、0-23）に raw 残数を確認し、残っていればバッチを自動実行する
# off にすると無効化。デフォルト: 3（深夜3時）/ バックエンドのデフォルト: lmstudio
# MIO_NIGHTLY_BATCH_HOUR=3
# MIO_NIGHTLY_BATCH_BACKEND=lmstudio
